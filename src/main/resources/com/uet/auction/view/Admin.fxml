<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uet.auction.client.controller.AdminController">

    <!-- Thanh Sidebar bên trái -->
    <left>
        <VBox prefHeight="600.0" prefWidth="200.0" spacing="10.0"
              style="-fx-background-color: #2c3e50;">
            <children>
                <Label text="ADMIN PANEL" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="30.0" left="20.0" top="20.0" />
                    </VBox.margin>
                </Label>

                <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent;"
                        text="Thống kê" textFill="WHITE" onAction="#handleMenuAction">
                    <padding>
                        <Insets left="30.0" />
                    </padding>
                </Button>

                <Button fx:id="btnUserMgmt" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent;"
                        text="Quản lý người dùng" textFill="WHITE" onAction="#handleMenuAction">
                    <padding>
                        <Insets left="30.0" />
                    </padding>
                </Button>

                <Button fx:id="btnProductMgmt" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent;"
                        text="Quản lý sản phẩm" textFill="WHITE" onAction="#handleMenuAction">
                    <padding>
                        <Insets left="30.0" />
                    </padding>
                </Button>

                <Region VBox.vgrow="ALWAYS" /> <!-- Đẩy nút đăng xuất xuống cuối -->

                <Button fx:id="btnLogout" alignment="BASELINE_LEFT" mnemonicParsing="false"
                        prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #e74c3c;"
                        text="Đăng xuất" textFill="WHITE" onAction="#handleLogout">
                    <padding>
                        <Insets left="30.0" />
                    </padding>
                </Button>
            </children>
        </VBox>
    </left>

    <!-- Vùng nội dung chính bên phải -->
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <children>
                <!-- Header phía trên -->
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="700.0"
                      style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <children>
                        <Label fx:id="lblPageTitle" text="Bảng điều khiển">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                            <HBox.margin>
                                <Insets left="20.0" />
                            </HBox.margin>
                        </Label>
                    </children>
                </HBox>

                <!-- Vùng chứa dữ liệu thay đổi (StackPane để tráo đổi các View con) -->
                <StackPane fx:id="contentArea" prefHeight="540.0" prefWidth="700.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <TableView fx:id="tableData" prefHeight="200.0" prefWidth="200.0">
                            <columns>
                                <TableColumn prefWidth="75.0" text="ID" />
                                <TableColumn prefWidth="200.0" text="Tên đối tượng" />
                                <TableColumn prefWidth="150.0" text="Ngày tạo" />
                                <TableColumn prefWidth="150.0" text="Trạng thái" />
                            </columns>
                        </TableView>
                    </children>
                </StackPane>
            </children>
        </VBox>
    </center>
</BorderPane>