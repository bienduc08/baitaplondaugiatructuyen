<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Thẻ VBox bọc ngoài cùng với hiệu ứng bo góc và đổ bóng -->
<VBox prefWidth="220.0" spacing="10.0"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.uet.auction.client.controller.ProductItemController">

    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <children>
        <!-- Khung chứa ảnh sản phẩm -->
        <VBox alignment="CENTER" prefHeight="160.0" style="-fx-background-color: #f5f6fa; -fx-background-radius: 10;">
            <children>
                <ImageView fx:id="imgProduct" fitHeight="150.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
                    <!-- Ảnh mặc định nếu sản phẩm chưa có ảnh -->
                    <image>
                        <Image url="@../images/Logo_HUET.svg.png" />
                    </image>
                </ImageView>
            </children>
        </VBox>

        <!-- Tên sản phẩm -->
        <Label fx:id="lblProductName" text="Tên sản phẩm">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <!-- Label phụ -->
        <Label text="Giá hiện tại:" textFill="#7f8c8d">
            <font>
                <Font size="13.0" />
            </font>
            <VBox.margin>
                <Insets bottom="-5.0" />
            </VBox.margin>
        </Label>

        <!-- Giá tiền -->
        <Label fx:id="lblCurrentPrice" text="0 đ" textFill="#e67e22">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <!-- Nút hành động -->
        <Button fx:id="btnBid" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleBidAction"
                prefHeight="40.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                text="Đấu giá ngay">
            <VBox.margin>
                <Insets top="5.0" />
            </VBox.margin>
        </Button>
    </children>
</VBox>
