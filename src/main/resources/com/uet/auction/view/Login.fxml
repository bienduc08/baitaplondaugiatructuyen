<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!-- Thẻ AnchorPane này là Root duy nhất, chứa fx:controller và xmlns -->

<AnchorPane prefHeight="450.0" prefWidth="650.0" style="-fx-background-color: white;" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.client.controller.LoginView">
   <children>
      <HBox prefHeight="450.0" prefWidth="650.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- PHẦN BÊN TRÁI: Logo và Thương hiệu UET -->
            <VBox alignment="CENTER" prefHeight="450.0" prefWidth="280.0" spacing="20.0" style="-fx-background-color: linear-gradient(to bottom right, #0074c2, #003355);">
               <children>
                  <ImageView fitHeight="163.0" fitWidth="171.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <!-- Đường dẫn từ file fxml tìm đến folder images -->
                        <Image url="@../images/LogoUET.png" />
                     </image>
                  </ImageView>-
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="VNU - UET" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label text="Hệ thống đấu giá trực tuyến" textFill="WHITE">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <effect>
                  <DropShadow />
               </effect>
            </VBox>

            <!-- PHẦN BÊN PHẢI: Form Đăng nhập & Đăng ký -->
            <VBox alignment="CENTER" prefHeight="450.0" prefWidth="370.0" spacing="15.0" style="-fx-background-color: white;">
               <padding>
                  <Insets left="40.0" right="40.0" />
               </padding>
               <children>
                  <Label text="ĐĂNG NHẬP" textFill="#00558d">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>

                  <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Tên đăng nhập" style="-fx-background-radius: 10;" />

                  <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="Mật khẩu" style="-fx-background-radius: 10;" />

                  <ComboBox fx:id="roleComboBox" prefHeight="40.0" prefWidth="300.0" promptText="Chọn vai trò" style="-fx-background-radius: 10;" />

                  <Button fx:id="btnLogin" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" style="-fx-background-color: #00558d; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="ĐĂNG NHẬP">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Button>

                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label text="Chưa có tài khoản?" />
                        <Hyperlink onAction="#handleShowRegister" style="-fx-font-weight: bold;" text="Đăng ký ngay" textFill="#00558d" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
