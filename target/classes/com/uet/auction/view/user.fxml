<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="540.0" prefWidth="700.0" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.client.controller.UserController">
    <children>
        <!-- Tiêu đề và Thanh tìm kiếm -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <TextField fx:id="txtSearch" prefHeight="35.0" prefWidth="400.0" promptText="Tìm kiếm sản phẩm đấu giá..." style="-fx-background-radius: 20;" />
                <Button fx:id="btnSearch" mnemonicParsing="false" prefHeight="35.0" prefWidth="80.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 20;" text="Tìm" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Số dư: " textFill="#27ae60">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <Label fx:id="lblBalance" text="0 VND">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
        </HBox>

        <!-- Danh mục nhanh -->
        <HBox spacing="10.0">
            <children>
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 15; -fx-background-radius: 15;" text="Tất cả" />
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 15; -fx-background-radius: 15;" text="Đồ điện tử" />
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 15; -fx-background-radius: 15;" text="Thời trang" />
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 15; -fx-background-radius: 15;" text="Đồ cổ" />
            </children>
        </HBox>

        <!-- Khu vực hiển thị sản phẩm -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="productContainer" hgap="20.0" prefWrapLength="650.0" vgap="20.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <!-- Các "Card" sản phẩm sẽ được load code động vào đây -->
                    <children>
                        <!-- Ví dụ một Card sản phẩm mẫu -->
                        <VBox prefHeight="200.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                            <children>
                                <StackPane prefHeight="100.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 10 10 0 0;">
                                    <children>
                                        <Label text="No Image" textFill="#bdc3c7" />
                                    </children>
                                </StackPane>
                                <VBox spacing="5.0">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="iPhone 15 Pro Max" />
                                        <Label text="Giá hiện tại:" textFill="#7f8c8d">
                                            <font>
                                                <Font size="11.0" />
                                            </font>
                                        </Label>
                                        <Label text="25.000.000đ" textFill="#e67e22">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Đấu giá ngay" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </FlowPane>
            </content>
        </ScrollPane>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>